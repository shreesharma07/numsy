{
  "displayName": "🔢 Numsy - A light-weight number processor",
  "name": "numsy",
  "version": "1.0.2",
  "description": "A professional TypeScript-based phone number processor with CSV/Excel parsing capabilities for Indian phone numbers. Class-based architecture with comprehensive error handling and logging.",
  "author": "Shri Kumar Sharma",
  "private": false,
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    },
    "./parser": {
      "require": "./dist/core/Parser.js",
      "import": "./dist/core/Parser.mjs",
      "types": "./dist/core/Parser.d.ts"
    }
  },
  "files": [
    "dist",
    "public",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "phone-number",
    "validator",
    "indian-phone",
    "csv-parser",
    "excel-parser",
    "number-processor",
    "numsy",
    "typescript",
    "phone-sanitizer",
    "contact-processor",
    "class-based",
    "phone-validation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/shreesharma07/numsy.git"
  },
  "bugs": {
    "url": "https://github.com/shreesharma07/numsy/issues"
  },
  "homepage": "https://github.com/shreesharma07/numsy#readme",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "swc src -d dist --copy-files && tsc --emitDeclarationOnly",
    "build:nest": "nest build",
    "dev": "nodemon",
    "dev:server": "nodemon --exec ts-node src/server.ts",
    "serve": "ts-node src/cli/server.ts",
    "serve:prod": "node dist/cli/server.js",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.js\"",
    "type-check": "tsc --noEmit",
    "start": "node dist/server.js",
    "start:nest": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/server.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prepare": "husky install",
    "prepublishOnly": "pnpm run build",
    "version": "pnpm run format && git add -A src",
    "postversion": "git push && git push --tags",
    "audit:fix": "pnpm audit --fix",
    "audit:check": "pnpm audit --audit-level=moderate",
    "snyk:test": "snyk test",
    "snyk:monitor": "snyk monitor",
    "snyk:protect": "snyk protect",
    "security:check": "pnpm audit:check && pnpm snyk:test",
    "precommit": "lint-staged",
    "validate": "pnpm run lint:check && pnpm run type-check && pnpm test",
    "ci": "pnpm run validate && pnpm run build",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run",
    "release:local": "semantic-release --extends ./.releaserc.local.json --dry-run --no-ci",
    "release:preview": "node scripts/release-preview.js",
    "npm:check": "node scripts/check-npm-status.js",
    "npm:fix-cooldown": "node scripts/fix-npm-cooldown.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/serve-static": "^4.0.0",
    "archiver": "^6.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "csv-parser": "^3.0.0",
    "csv-writer": "^1.6.0",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.6.1",
    "@commitlint/config-conventional": "^18.6.3",
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^11.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^9.2.6",
    "@semantic-release/npm": "^11.0.3",
    "@semantic-release/release-notes-generator": "^12.1.0",
    "@swc/cli": "^0.1.63",
    "@swc/core": "^1.3.105",
    "@types/archiver": "^6.0.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.5",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "conventional-changelog-conventionalcommits": "^7.0.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.2",
    "nodemon": "^3.0.3",
    "prettier": "^3.2.4",
    "rimraf": "^5.0.5",
    "semantic-release": "^23.1.1",
    "snyk": "^1.1303.1",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.spec.json"
        }
      ]
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s",
      "!src/**/*.spec.ts",
      "!src/**/*.test.ts",
      "!src/main.ts",
      "!src/server.ts"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src/",
      "<rootDir>/test/"
    ]
  }
}
